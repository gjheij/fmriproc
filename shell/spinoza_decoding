#!/usr/bin/env bash

source "${SETUP_FILE}"
source call_bashhelper

function Usage {
    cat <<USAGE
---------------------------------------------------------------------------------------------------
spinoza_decoding

SLURM-array launcher for subject-wise PANIC jobs.

Usage:
  spinoza_decoding [arguments] [options] <project root> -- [PANIC/call_panic-style arguments]

Arguments:
  -s <subject>    subject ID, e.g. 001 or sub-001. Can be comma-separated.
  -j <n_cpus>     number of CPUs per subject/job. Default = 4
  -q <queue>      SLURM queue/partition. Default = \$SGE_QUEUE_LONG
  -m <n_jobs>     maximum number of subjects running simultaneously. Default = 10
  -d <source>     derivative source directory. Default = halfpipe
  -r <roi_base>   the ROI-directory is based on <project root>/derivatives/rois/<subject>/<roi_base>.
                  If --searchlight is passed, 'searchlight' is appended. This can be changed with
                  the '-r' flag.
Options:
  -h|--help       print help
  --local         run subjects sequentially via call_panic
  --dry-run       print commands but do not submit/run
  --overwrite     whether to overwrite existing outputs. Default: False. If True,
                  existing outputs will be overwritten; if False, existing outputs will
                  be preserved and the corresponding subject/job will be skipped.

Pass-through:
  After '--', supports call_panic-style -f, -x, --searchlight, --lsa, --lss,
  plus direct PANIC arguments.

---------------------------------------------------------------------------------------------------
USAGE
}

sub=""
n_cpus=4
source="halfpipe"
run_local=0
dry_run=0
max_running=10
overwrite=()
overwrite_arg=False
searchlight_base_dir="searchlight"
SGE_QUEUE="${SGE_QUEUE_LONG:-main}"
panic_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s)
      sub="$2"; shift 2 ;;
    -j)
      n_cpus="$2"; shift 2 ;;
    -q)
      SGE_QUEUE="$2"; shift 2 ;;
    -m|--max-running)
      max_running="$2"; shift 2 ;;
    -d|--source)
      source="$2"; shift 2 ;;
    -r|--roi-base)
      searchlight_base_dir="$2"; shift 2 ;;
    --local)
      run_local=1; shift ;;
    --dry-run)
      dry_run=1; shift ;;
    --overwrite|--ow|-o)
      overwrite=(--overwrite)
      overwrite_arg=True
      shift
      ;;
    -h|--help)
      Usage; exit 0 ;;
    --)
      shift
      panic_args=("$@")
      break ;;
    -*)
      print_error_msg "$(basename "${0}")" "getopt" "Unknown option $1"
      Usage
      exit 1 ;;
    *)
      proj_dir="$1"; shift ;;
  esac
done

if [[ -z "${proj_dir:-}" ]]; then
  Usage
  print_error_msg "$(basename "${0}")" "input" "Project directory not specified"
  exit 1
fi

proj_dir="$(realpath "${proj_dir}")"
source_root="${proj_dir}/derivatives/${source}"
work_dir="${proj_dir}/logs"
save_dir="${proj_dir}/derivatives/decoding"
roi_root="${proj_dir}/derivatives/rois"

mkdir -p "${work_dir}" "${save_dir}"

if [[ ! -d "${source_root}" ]]; then
  print_directory_not_exist "Source" "${source_root}"
  exit 1
fi

# Parse pass-through args into PANIC-native pieces
panic_global_args=()
panic_run_args=()
extra_sets=()
searchlight=0
method="LSA"

i=0
while [[ $i -lt ${#panic_args[@]} ]]; do
  arg="${panic_args[$i]}"

  case "${arg}" in
    -f|--config|-c)
      i=$((i + 1))
      panic_global_args+=("-c" "${panic_args[$i]}")
      ;;
    -x)
      i=$((i + 1))
      IFS=',' read -ra parsed_sets <<< "${panic_args[$i]}"
      unset IFS
      extra_sets+=("${parsed_sets[@]}")
      ;;
    --set)
      i=$((i + 1))
      extra_sets+=("${panic_args[$i]}")
      ;;
    --searchlight)
      searchlight=1
      panic_run_args+=("--searchlight")
      ;;
    --lsa)
      method="LSA"
      ;;
    --lss)
      method="LSS"
      ;;
    *)
      panic_run_args+=("${arg}")
      ;;
  esac

  i=$((i + 1))
done

subject_file="${work_dir}/panic_subjects.txt"

if [[ -n "${sub}" ]]; then
  IFS=', ' read -r -a subjects <<< "${sub}"
  unset IFS

  : > "${subject_file}"
  for subject in "${subjects[@]}"; do
    subject="${subject#sub-}"
    echo "sub-${subject}" >> "${subject_file}"
  done
else
  find "${source_root}" -maxdepth 1 -mindepth 1 \( -type d -o -type l \) |
    xargs -n1 basename |
    grep '^sub-' |
    sort > "${subject_file}"
fi

n_subjects=$(wc -l < "${subject_file}" | tr -d ' ')

if [[ "${n_subjects}" -eq 0 ]]; then
  print_error_msg "$(basename "${0}")" "input" "No subjects found"
  exit 1
fi

runner="${work_dir}/panic_array_runner.sh"

cat <<EOF > "${runner}"
#!/usr/bin/env bash
source "${SETUP_FILE}"
source call_bashhelper

subject=\$(sed -n "\${SLURM_ARRAY_TASK_ID}p" "${subject_file}")

if [[ -z "\${subject}" ]]; then
  echo "ERROR: no subject found for SLURM_ARRAY_TASK_ID=\${SLURM_ARRAY_TASK_ID}" >&2
  exit 1
fi

roi_dir="${roi_root}/\${subject}"
EOF

if [[ "${searchlight}" -eq 1 ]]; then
cat <<'EOF' >> "${runner}"
roi_dir="${roi_dir}/${searchlight_base_dir}"
EOF
fi

cat <<EOF >> "${runner}"

set_keys=(
  general_settings.project_dir="${proj_dir}"
  general_settings.save_dir="${save_dir}"
  decoding_settings.parallel.n_jobs="${n_cpus}"
  general_settings.source="${source}"
  general_settings.method="${method}"
  roi_dict="\${roi_dir}"
  general_settings.overwrite="${overwrite_arg}"
)
EOF

for s in "${extra_sets[@]}"; do
  printf 'set_keys+=(%q)\n' "${s}" >> "${runner}"
done

cat <<'EOF' >> "${runner}"

cmd=(
  panic
EOF

for arg in "${panic_global_args[@]}"; do
  printf '  %q\n' "${arg}" >> "${runner}"
done

cat <<'EOF' >> "${runner}"
  run
  --subject "${subject}"
EOF

for arg in "${panic_run_args[@]}"; do
  printf '  %q\n' "${arg}" >> "${runner}"
done

cat <<'EOF' >> "${runner}"
  --set
  "${set_keys[@]}"
)

print_cmd "${cmd[@]}"
"${cmd[@]}"
EOF

chmod +x "${runner}"

array_spec="1-${n_subjects}%${max_running}"

if [[ "${dry_run}" -eq 1 ]]; then
  echo "Subject file: ${subject_file}"
  echo "Runner: ${runner}"
  echo "Array: ${array_spec}"
  echo "Queue: ${SGE_QUEUE}"
  echo "CPUs: ${n_cpus}"
  echo
  echo "Runner content:"
  cat "${runner}"
  echo
  echo "Would submit:"
  echo "sbatch --partition=${SGE_QUEUE} --array=${array_spec} --cpus-per-task=${n_cpus} --job-name=panic --output=${work_dir}/panic_%A_%a.out ${runner}"
  exit 0
fi

if [[ "${run_local}" -eq 1 ]]; then
  start_timer "Running PANIC locally"

  while read -r subject; do
    cmd=(
      call_panic
      -p "${proj_dir}"
      -u "${subject}"
      -c "${n_cpus}"
      -s "${source}"
      -q "${SGE_QUEUE}"
      -r "${searchlight_base_dir}"
      "${overwrite[@]}"
      --local
      "${panic_args[@]}"
    )

    print_cmd "${cmd[@]}"
    "${cmd[@]}"
  done < "${subject_file}"

  end_timer
else
  sbatch \
    --partition="${SGE_QUEUE}" \
    --array="${array_spec}" \
    --cpus-per-task="${n_cpus}" \
    --job-name="panic" \
    --output="${work_dir}/panic_%A_%a.out" \
    "${runner}"
fi