#!/usr/bin/env bash

#-----------------------------------------------------------------------------
# source setup and helper functions
call_loadsetup
source call_bashhelper


#-----------------------------------------------------------------------------
# Create help text
function Usage {
    cat <<USAGE

---------------------------------------------------------------------------------------------------
call_injectmatrices

Follow workflow https://mumfordbrainstats.tumblr.com/post/166054797696/feat-registration-workaround
To use fMRIprep output in FEAT. Uses the mean of the functional run as 'standard', rather than the
MNI152-image.

Arguments:
  -p <proj dir>   project root folder (defaults to DIR_DATA_HOME)
  -l <level1 tag> tag for level1 analysis (e.g., 'level1' [default] or 'level1_confounds')
  -f <feat dir>   directory where your subject-specific feat-directories live (defaults to DIR-
                  DATA_HOME/derivatives/feat/<level1_tag>)
  -t <file>       use this file as template. Defaults to <feat dir>/mean_func.nii.gz

Options:
  -h|--help       print this help text

Example:
  # show this help
  call_injectmatrices --help

  # run script for all .feat-folders in DIR_DATA_HOME/derivatives/feat/<level1_tag>
  call_injectmatrices 

  # run script for all feat-folders in 'feat_dir/sub-01'
  call_injectmatrices -p feat_dir/sub-01

Notes:
  If you have functional data in T1w space but in BOLD voxel space, you first
  need to create an ANTs transformation for the identity matrix, then convert
  that to FSL:

  1) call_createident ident.txt
  2) call_ras2fsl highres.nii.gz example_func.nii.gz ident.txt example_func2highres.mat
  3) updatefeatreg

  If you specify the T1w to be the template for call_injectmatrices, you can use
  the \$FSLDIR/etc/flirtsch/ident.mat for highres2standard.nii.gz

---------------------------------------------------------------------------------------------------

USAGE

}

SPACE=""
# Check for subject & session flags
while getopts :-:hs:l:n:r:f:p:t: argument
do
  case ${argument} in
    -)
      case "${OPTARG}" in
        help)
          Usage && exit 0
          ;;
        *)
          Usage
          print_error_msg "$(basename ${0})" "getopt" "Unknown option --${OPTARG}"
          exit 1
          ;;
      esac
      ;;
    h)  Usage && exit 0
          ;; 
    l)  L1_tag="${OPTARG}"
          ;;
    f)  ft_dir="${OPTARG}"
          ;;
    p)  project_dir="${OPTARG}"
          ;;
    t)  template="${OPTARG}"
          ;;          
  esac
done

#-----------------------------------------------------------------------------
# define single-use functon
check_and_make_mat() {
  local ref="$1"
  local mov="$2"
  local outmat="$3"

  local same_affine
  same_affine=$(
  python - "$ref" "$mov" <<'PY'
import sys
import nibabel as nb
import numpy as np

a = nb.load(sys.argv[1]).affine
b = nb.load(sys.argv[2]).affine

print(int(np.allclose(a, b, rtol=0, atol=1e-5)))
PY
    )

    if [[ "$same_affine" == "1" ]]; then
      echo -e "Affines of ${BOLD_GREEN}$(basename $ref)${RESET} and ${BOLD_GREEN}$(basename ${mov})${RESET} are the same; using ident.mat"
      cp "${FSLDIR}/etc/flirtsch/ident.mat" "$outmat"
    else
      echo -e "Affines of ${BOLD_GREEN}$(basename $ref)${RESET} and ${BOLD_GREEN}$(basename ${mov})${RESET} are ${BOLD_RED}not${RESET} the same; using ANTs identity"
      tmp_ident="${outmat%.mat}_ident.txt"
      call_createident "$tmp_ident"
      call_ras2fsl "$ref" "$mov" "$tmp_ident" "$outmat"

      rm -f "$tmp_ident"
    fi
}

function fix_reg_dir {
  local feat_dir="${1}"
  local template_img="${template:-${feat_dir}/mean_func.nii.gz}"
  local func_img="${feat_dir}/mean_func.nii.gz"
  
  if [[ -d "${feat_dir}" ]]; then

    echo -e "Processing ${BOLD_MAGENTA}${feat_dir}${RESET}"

    if [[ ! -f "${template_img}" ]]; then
      echo
      print_line -
      print_error_msg "$(basename ${0})" "template" "Template image \"${template_img}\" does not exist."
      return 1
    else
      echo -e "Template image: ${BOLD_GREEN}${template_img}${RESET}"
    fi

    rm -r "${feat_dir}/reg_standard" 2>/dev/null
    rm -r "${feat_dir}/reg" 2>/dev/null

    mkdir -p "${feat_dir}/reg"

    # define relevant images
    highres="${feat_dir}/reg/highres.nii.gz"
    example_func="${feat_dir}/reg/example_func.nii.gz"
    standard="${feat_dir}/reg/standard.nii.gz"
    
    # copy
    cp "${template_img}" "${standard}"
    cp "${template_img}" "${highres}"
    cp "${func_img}" "${example_func}"

    # check affines to see if we can use pure ident.mat
    check_and_make_mat \
      "${highres}" \
      "${example_func}" \
      "${feat_dir}/reg/example_func2highres.mat"

    check_and_make_mat \
      "${standard}" \
      "${highres}" \
      "${feat_dir}/reg/highres2standard.mat"

    check_and_make_mat \
      "${standard}" \
      "${example_func}" \
      "${feat_dir}/reg/example_func2standard.mat"

    cmd=(updatefeatreg "${feat_dir}")
    print_cmd "${cmd[@]}" && eval "${cmd[@]}"
    
  else
    echo "Feat directory does not exists"
    return 1
  fi
}

#-----------------------------------------------------------------------------
# specify defaults
if [[ -z "${project_dir}" ]]; then
  project_dir="${DIR_DATA_HOME}"
fi

#-----------------------------------------------------------------------------
# set level1 tag
if [[ -z "${L1_tag}" ]]; then
  L1_tag="level1"
else
  L1_tag="${L1_tag}"
fi

#-----------------------------------------------------------------------------
# set full directory
if [[ -z "${ft_dir}" ]]; then
  ft_dir="${project_dir}/derivatives/feat/${L1_tag}"
fi

if [[ ! -d "${ft_dir}" ]]; then
  echo
  print_line -
  print_error_msg "$(basename ${0})" "find" "Directory \"${ft_dir}\" does not exist.."
  exit 1
fi

#-----------------------------------------------------------------------------
# find all .feat directories and run command
if [[ "${ft_dir}" == *.feat ]]; then
  all_feats=("${ft_dir}")
else
  all_feats=(
    $(
      find "${ft_dir}" \
      -type d \
      -name "*.feat"
    )
  )
fi

#-----------------------------------------------------------------------------
# run
for ft in ${all_feats[@]}; do
  fix_reg_dir "${ft}"
  if [[ $? -ne 0 ]]; then
    echo
    print_line -
    print_error_msg "$(basename ${0})" "fix_reg_dir"
    exit 1
  fi
done

echo "Done"
