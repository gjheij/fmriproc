#!/usr/bin/env bash

#-----------------------------------------------------------------------------
# Get bash helper functions
source call_bashhelper

#-----------------------------------------------------------------------------
# Create help text
function Usage {
    cat <<USAGE

---------------------------------------------------------------------------------------------------
call_fmriprep

Wrapper around fMRIPrep. The workflow can be run directly, through Docker, or through a Singularity
container, depending on the selected options and available environment. Cluster execution is handled
outside the fMRIPrep command itself; supported schedulers are detected from the presence of 'squeue'
or 'qstat' where relevant.

The wrapper is intentionally simpler than calling fMRIPrep directly. Common project-specific options
are exposed as flags, while additional fMRIPrep arguments can be supplied through a kwargs file.

Usage:
  call_fmriprep [arguments] [options]

Mandatory:
  -s <sub number> subject identifier. The "sub-" prefix may be omitted
                  e.g., use "001" for "sub-001"

Optional arguments:
  -m <mode>       preprocessing mode. Use 'anat' for anatomical-only preprocessing.
                  Any other value runs the functional workflow as well. Default: anat
  -r <root>       BIDS project root directory. Default: \$DIR_DATA_HOME
  -d <deriv>      derivatives directory. Default: \$DIR_DATA_DERIV
  -i <simg>       Singularity image used when running through Singularity
  -b <binding>    Singularity bind path. Default: \$PATH_HOME
  -c <n_threads>  number of threads passed to fMRIPrep. Default: 15
  -w <work>       fMRIPrep working directory for intermediate files.
                  Default: \$PATH_HOME/fmriprep/\$PROJECT
  -l <license>    FreeSurfer license file. When using Singularity, this path must be
                  accessible from within the bind path
  -x <config>     BIDS filter file passed to fMRIPrep with --bids-filter-file
  -t <task ID>    restrict preprocessing to one task using --task-id
  -k <kwargs>     text file with additional fMRIPrep arguments, one argument or
                  argument-value pair per line
  -a <keep runs>  comma- or space-separated run IDs for which MNI152 preprocessed
                  BOLD files should be kept. By default, generated MNI152
                  preprocessed BOLD NIfTIs are removed to save disk space while
                  transformation files are retained. Use '-a all' to keep all runs

Options:
  -h|--help       print this help text
  --docker        use fmriprep-docker instead of Singularity or a direct fmriprep call
  --sge           legacy option for Singularity-based cluster use; the Singularity
                  image should be defined in the setup file or provided with -i
  --clean         remove the subject-specific fMRIPrep working directory after a
                  successful run. This saves disk space, but prevents resuming from
                  previous intermediate results
  --try           do not pass --stop-on-first-crash. This lets fMRIPrep continue after
                  recoverable errors, but failed nodes should still be inspected

Example:
  call_fmriprep -s 001
  call_fmriprep -s 001 -m anat
  call_fmriprep -s 001 -m func -t localizer
  call_fmriprep -s 001 -m func -a 1,2

Notes:
  - By default, only the anatomical workflow is run. This allows inspection of the
    anatomical preprocessing and FreeSurfer reconstruction before running the
    functional workflow. Run the command again with a non-'anat' mode to include
    functional preprocessing.
  - Output spaces are controlled by FPREP_ANAT_SPACES and FPREP_OUTPUT_SPACES in
    the setup/configuration file. FPREP_ANAT_SPACES is used for anatomical-only
    runs when defined; FPREP_OUTPUT_SPACES is used for full runs.
  - The separation between anatomical and functional output spaces allows transform
    files to be generated without necessarily resampling every functional time
    series to every template space.
  - Additional fMRIPrep options may be supplied with -k. Options that are managed
    by this wrapper or the setup file are ignored when encountered in the kwargs
    file to avoid conflicting command-line settings.

---------------------------------------------------------------------------------------------------

USAGE

}

#-----------------------------------------------------------------------------
# Deal with arguments
bbr_flag=""
mode="anat"
anat_only_flag="--anat-only"
derivatives="${DIR_DATA_DERIV}"
license="${REPO_DIR}/misc/license.txt"
cifti_flag=""
config_flag=""
task_flag=""
syn_flag=""
init_flag=""
fprep_container="${FPREP_SIMG}"
project="${DIR_DATA_HOME}"
work="${PATH_HOME}/fmriprep/${PROJECT}"
KWARGS_FILE=""
clean_wd=0
USE_DOCKER=0
crash_flag="--stop-on-first-crash"
while getopts :-:hus:m:r:d:c:i:b:w:l:x:t:k:a: arg
do
  case ${arg} in
    -)
      case "${OPTARG}" in
        no-bbr)
          bbr_flag="--force-no-bbr"
          # cannot use no-bbr and header registration so make init variable empty
          BOLD_T1W_INIT=""
          ;;
        docker)
          USE_DOCKER=1
          ;; 
        clean)
          clean_wd=1
          ;;  
        try)
          crash_flag=""
          ;; 
        help)
          Usage && exit 0
          ;;
        *)
          Usage
          print_error_msg "$(basename ${0})" "getopt" "Unknown option --${OPTARG}"
          exit 1
          ;;
      esac
      ;;
    s)  subj_ID="${OPTARG}"
          ;;
    m)  MODE="${OPTARG}"
          ;;
    r)  ROOT="${OPTARG}"
          ;;
    d)  DERIV="${OPTARG}"
          ;;
    i)  IMG="${OPTARG}"
          ;;
    b)  BIND="${OPTARG}"
          ;;
    w)  WORK="${OPTARG}"
          ;;
    l)  LIC="${OPTARG}"
          ;;
    x)  CONFIG="${OPTARG}"
          ;;
    t)  TASK_ID="${OPTARG}"
          ;;
    k)  KWARGS_FILE="${OPTARG}"
          ;;
    c)  n_threads="${OPTARG}"
          ;; 
    a)  keep_runs="${OPTARG}"
          ;;
    h)  Usage && exit 0
          ;;
  esac
done

if [[ $# -lt 1 || -z ${subj_ID} ]] ; then
  Usage
  echo "Need at least a subject ID"
  exit 1
fi

if [[ ! -z ${keep_runs} ]]; then
  # read specified subjects into array
  IFS=', ' read -r -a keep_runs <<< "${keep_runs}"
  unset IFS
fi

# check kwargs file
if [[ ! -z "${KWARGS_FILE}" ]]; then

  echo "Including kwargs from \"${KWARGS_FILE}\":"  
  
  # exclude these flags; these should be specified in spinoza_setup or command line
  flags_from_setup=(
    "--cifti-output"
    "--bids-filter-file"
    "--task-id"
    "--use-syn-sdc"
    "--bold2t1w-init"
  )
  
  kwargs=()
  while read -r line; do

    re="[[:space:]]+"
    if [[ $line =~ $re ]]; then
      fl=$(echo ${line} | cut -d" " -f1)
      ar=$(echo ${line} | cut -d" " -f2)
    else
      fl=${line}
      ar=""
    fi
    
    if [[ "${flags_from_setup[@]}" =~ "${fl}" ]]; then
      echo "WARNING: \"${fl}\" flag specified in kwargs-file, but this setting is defined in \"${SETUP_FILE}\". Skipping.."
    else
      echo "${line}"
      kwargs+=(${line})
    fi
  done < "${KWARGS_FILE}"
fi

#-----------------------------------------------------------------------------
# Set default mode if none specified
if [[ ! -z ${MODE} ]]; then
  mode=${MODE}
fi

#-----------------------------------------------------------------------------
# Set default project root directory if none specified
if [[ ! -z "${ROOT}" ]]; then
  project="${ROOT}"
fi

if [[ ! -d "${project}" ]]; then
  mkdir -p "${project}"
fi

#-----------------------------------------------------------------------------
# Set default derivatives directory if none specified
if [[ ! -z "${DERIV}" ]]; then
  derivatives="${DERIV}"
fi

if [[ ! -d "${derivatives}" ]]; then
  mkdir -p "${derivatives}"
fi

#-----------------------------------------------------------------------------
# Set default working directory if none specified
if [[ ! -z "${WORK}" ]]; then
  work="${WORK}"
fi

if [[ ! -d "${work}" ]]; then
  mkdir -p "${work}"
fi

#-----------------------------------------------------------------------------
# Set default FS-license if none specified
if [[ ! -z "${FS_LICENSE}" ]]; then
  license="${FS_LICENSE}"
fi

# make -l flag overwrite environmental variable
if [[ ! -z "${LIC}" ]]; then
  license="${LIC}"
fi

#-----------------------------------------------------------------------------
# Check if we need to output CIFTIs
if [[ ! -z "${CIFTI}" ]]; then
  cifti_flag="--cifti-output ${CIFTI}"
fi

#-----------------------------------------------------------------------------
# Check if we received configuration file
if [[ ! -z "${CONFIG}" ]]; then
  config_flag="--bids-filter-file ${CONFIG}"
fi

#-----------------------------------------------------------------------------
# Check if we received task ID
if [[ ! -z "${TASK_ID}" ]]; then
  task_flag="--task-id ${TASK_ID}"
fi

#-----------------------------------------------------------------------------
# Check if we need to output CIFTIs
if [[ ${DO_SYN} -eq 1 ]]; then
  syn_flag="--use-syn-sdc"
fi

#-----------------------------------------------------------------------------
# Set default container if none specified
if [[ ! -z "${IMG}" ]]; then
  fprep_container="${IMG}"
fi

#-----------------------------------------------------------------------------
# Set default binding point if none specified
if [[ -z "${BIND}" ]]; then
  binding="${PATH_HOME}"
else
  binding="${BIND}"
fi

#-----------------------------------------------------------------------------
# Define command line
if [[ ${USE_DOCKER} -eq 1 ]]; then
  run_cmd="fmriprep-docker"
else
  if [[ -f "${fprep_container}" ]]; then

    echo -e "Singularity image: ${BOLD_GREEN}${fprep_container}${RESET}"
    if [[ ! -f "${fprep_container}" ]]; then
      echo
      print_line -
      print_error_msg "$(basename ${0})" "find" "Could not find singularity image \"${fprep_container}\" for fmriprep.."
      exit 1
    fi 

    # check if FS license is within binding point
    if [[ "${license}" != *"${binding}"* ]]; then
      echo
      print_line -
      print_error_msg "$(basename ${0})" singularity "Your license file \"${license}\" cannot be accessed due to your binding point (\"${binding}\"). Please make sure the file on somewhere along the binding-path"
      exit 1
    fi

    # check if project root is within binding point
    if [[ "${project}" != *"${binding}"* ]]; then
      echo
      print_line -
      print_error_msg "$(basename ${0})" singularity "Your project root \"${project}\" cannot be accessed due to your binding point (\"${binding}\"). Please make sure the file on somewhere along the binding-path"
      exit 1
    fi

    # define SGE command |  -B /mnt/d/fMRI/HRA/nipype.cfg:/home/fmriprep/.nipype/nipype.cfg:ro
    run_cmd="singularity run --cleanenv -B ${binding}:${binding} ${fprep_container}"

  else
    echo "WARNING: system is setup to use singularity, but image \"${fprep_container}\" could not be found. Defaulting to \"fmriprep\"-command"
    run_cmd="fmriprep"
  fi
fi

#-----------------------------------------------------------------------------
# overwrite anat only if 'func' is specified
use_output_spaces="${FPREP_OUTPUT_SPACES}"
if [[ ${mode} != "anat" ]]; then
  anat_only_flag=""
else
  if [[ ! -z "${FPREP_ANAT_SPACES}" ]]; then
    use_output_spaces="${FPREP_ANAT_SPACES}"
  fi
fi

#-----------------------------------------------------------------------------
# set nthreads
if [[ -z ${n_threads} ]]; then
  nthreads=15
else
  nthreads=${n_threads}
fi
nthread_flag="--nthreads ${nthreads}"

#-----------------------------------------------------------------------------
# output directory structure has changed after v21: https://github.com/nipreps/fmriprep/releases/tag/21.0.0
echo "Checking fMRIPrep's version.."
version_string=$(eval ${run_cmd} --version)
if [[ $? -ne 0 ]]; then
  echo
  print_line -
  print_error_msg "$(basename ${0})" eval "Could not derive version:"
  echo "${version}"
  exit 1
fi

major_version=$(echo "$version_string" | grep -oP 'fMRIPrep v\K\d+' | cut -d"." -f1)
if [[ "${major_version}" -lt 21 ]]; then
  output_dir="${derivatives}"
  single_subj_wf="single_subject_${subj_ID}_wf"
  func_wf="func_preproc"

  #-----------------------------------------------------------------------------
  # Check how to initialize bold-to-T1w registration
  if [[ ${BOLD_T1W_INIT} == "register" ]] || [[ ${BOLD_T1W_INIT} == "header" ]]; then
    init_flag="--bold2t1w-init ${BOLD_T1W_INIT}"
  fi    
else
  output_dir="${derivatives}/fmriprep"
  single_subj_wf="sub_${subj_ID}_wf"
  func_wf="bold"

  #-----------------------------------------------------------------------------
  # Check how to initialize bold-to-T1w registration
  if [[ ${BOLD_T1W_INIT} == "register" ]] || [[ ${BOLD_T1W_INIT} == "header" ]]; then
    if [[ ${BOLD_T1W_INIT} == "register" ]]; then
      export BOLD_T1W_INIT="auto"
    fi
    init_flag="--bold2anat-init ${BOLD_T1W_INIT}"
  fi    
fi

#-----------------------------------------------------------------------------
# define the fMRIPrep command
cmd=(
  "${run_cmd}"
  "${project}"
  "${output_dir}"
  participant
  --participant-label "${subj_ID}"
  --skip-bids-validation
  --md-only-boilerplate
  --fs-license-file "${license}"
  --output-spaces "${use_output_spaces}"
  --fs-subjects-dir "${FS}"
  --work-dir "${work}"
  "${crash_flag}"
  "${bbr_flag}"
  "${cifti_flag}"
  "${syn_flag}"
  "${config_flag}"
  "${task_flag}"
  "${init_flag}"
  "${anat_only_flag}"
  "${nthread_flag}"
  "${kwargs[@]}"
)

#-----------------------------------------------------------------------------
# execute
print_cmd "${cmd[@]}" && eval "${cmd[@]}"

if [[ $? -ne 0 ]]; then
  echo
  print_line -
  print_error_msg "$(basename ${0})" "${run_cmd}" "Job submission/execution was unsuccessful."
  exit 1
fi   

#-----------------------------------------------------------------------------
# remove large MNI152*-files
if [[ ! -z ${keep_runs} ]]; then
  if [[ ${keep_runs} != "all" ]]; then
    
    # find files
    fprep_="${derivatives}/fmriprep/sub-${subj_ID}"
    mni_files=(
      $(
        find -L "${fprep_}" \
        -type f \
        -name "*MNI152*" \
        -and -name "*_desc-preproc_bold.nii.gz" \
        2>/dev/null
      )
    )

    # loop
    if [[ ! -z "${mni_files}" ]]; then
      for mni in "${mni_files[@]}"; do
        # find run_id and compare against keep_runs
        run_id=$(get_id ${mni} run)

        # remove if run_id not in keep_runs
        if [[ ! " ${keep_runs[*]} " =~ " ${run_id} " ]]; then
          echo "removing ${mni} to save storage.."
          rm -r "${mni}" 2>/dev/null
        fi
      done
    fi
  else
    echo "Keeping all runs containing MNI152.. Check if this is OK with your storage usage"
  fi
fi

#-----------------------------------------------------------------------------
# check if we should clean working directory
if [[ ${clean_wd} -eq 1 ]]; then  
  wf_folder=$(
    find "${work}" \
    -maxdepth 1 \
    -type d \
    -name "fmriprep*" \
    -and -name "*wf" \
    2>/dev/null
  )

  if [[ ! -z "${wf_folder}" ]]; then
    subj_wf="${wf_folder}/${single_subj_wf}"

    if [[ -d "${subj_wf}" ]]; then
      echo -e "Removing ${BOLD_GREEN}${subj_wf}${RESET}"
      rm -r "${subj_wf}" 2>/dev/null
    else
      echo "Could not find/remove \"${subj_wf}\""
    fi
  else
    echo -e "Could not find directory containing \"fmriprep\" and \"wf\" in ${BOLD_GREEN}${work}${RESET}"
  fi
fi
